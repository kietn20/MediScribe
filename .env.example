# Copy this to .env and fill in real values. Never commit .env.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=mediscribe
POSTGRES_USER=mediscribe_user
POSTGRES_PASSWORD=changeme_local

# ── Spring Boot datasource ──────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mediscribe
SPRING_DATASOURCE_USERNAME=mediscribe_user
SPRING_DATASOURCE_PASSWORD=changeme_local

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_256_bit_hex_secret
JWT_EXPIRATION_MS=86400000

# ── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=

# ── ElevenLabs  ───────────────────────────────────────────
ELEVENLABS_API_KEY=
